  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">#centralwidget{
    background-color: #F8F8F8;
}

/* Sign Up */
QLabel#label_2{
    color: #333333;
    font: 700 24pt &quot;Poppins&quot;;
}

/* Create account text */
QLabel#label_3, QLabel#label_5{
    color: #666666;
    font: 11pt &quot;Poppins&quot;;
}

/* Label Fullname Email Password */
#text_full_name,
#text_e_number,
#text_password{
    color: #333333;
    font: 600 15pt &quot;Poppins&quot;;
}

/* Input */
#Full_name,
#email,
#password{
    background-color: white;
    border: 2px solid #D9D9D9;
    border-radius: 12px;
    padding-left: 10px;
    color: #333333;
    font: 15pt &quot;Poppins&quot;;
}

/* Nút Sign Up */
#signup, #nav_login{
    background-color: #4CAF50;
    color: white;
    border-radius: 15px;
    border: none;
    font: bold 11pt &quot;Poppins&quot;;
}

#signup:hover, #nav_login:hover{
    background-color: #43A047;
}

/* Login Link */
#forgot{
    background: transparent;
    color: #4CAF50;
    border: none;
    font: 10pt &quot;Poppins&quot;;
}

#forgot:hover{
    color: #43A047;
    text-decoration: underline;
}
</string>
